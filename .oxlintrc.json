{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import", "vue"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-unused-vars": "warn",
    "import/no-duplicates": "warn"
  },
  "ignorePatterns": [".nuxt", ".output", "dist", "node_modules"]
}
